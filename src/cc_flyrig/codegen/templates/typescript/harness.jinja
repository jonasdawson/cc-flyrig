// Source schema: cc-{{ cc_version }} ({{ schema_date }}). Re-scaffold when Claude Code is upgraded.
// Event: {{ event }}. Wire this package into settings.json yourself.

import { readFileSync } from "node:fs";

{{ emit_model(specs) }}

{% if decision_pattern == "none" %}
export function run(handle: (event: {{ input_class }}) => void): void {
  const event = parse{{ input_class }}(JSON.parse(readStdin()));
  // Non-blocking event. Side-effect only — no output is serialized.
  handle(event);
}
{% elif decision_pattern == "worktree-path-return" %}
export function run(handle: (event: {{ input_class }}) => {{ output_class }} | null): void {
  const event = parse{{ input_class }}(JSON.parse(readStdin()));
  // Blocking event. Command hooks print the worktree path to stdout as a bare string (not JSON).
  const decision = handle(event);
  if (decision !== null && decision.hookSpecificOutput != null) {
    console.log(decision.hookSpecificOutput.worktreePath);
  }
}
{% elif decision_pattern == "text-return" %}
export function run(handle: (event: {{ input_class }}) => string): void {
  const event = parse{{ input_class }}(JSON.parse(readStdin()));
  // Freeform text surface (statusLine). No output model — print exactly what handle() returns.
  console.log(handle(event));
}
{% elif decision_pattern == "jsonlines-rows" %}
export function run(handle: (event: {{ input_class }}) => {{ output_class }}[]): void {
  const event = parse{{ input_class }}(JSON.parse(readStdin()));
  // subagentStatusLine: one {{ output_class }} row per visible subagent, one JSON object per line.
  for (const row of handle(event)) {
    console.log(JSON.stringify(serialize{{ output_class }}(row)));
  }
}
{% else %}
export function run(handle: (event: {{ input_class }}) => {{ output_class }} | null): void {
  const event = parse{{ input_class }}(JSON.parse(readStdin()));
{% if decision_pattern == "hookSpecificOutput-permissionDecision" %}
  // Blocking event. Exit 0 with JSON whose hookSpecificOutput.permissionDecision is one of
  // allow / deny / ask / defer. To deny via exit code instead, write a reason to stderr and
  // process.exit(2). Returning null takes no action and lets other hooks / the default decide.
{% elif decision_pattern == "top-level-decision" %}
  // Blocking event. Set decision="block" and reason to stop the action. Returning null allows.
{% elif decision_pattern == "context-only" %}
  // Non-blocking event. Set hookSpecificOutput fields to inject context. Returning null is a no-op.
{% elif decision_pattern == "exit-code-or-continue" %}
  // Blocking event. Set continue=false to stop (or write a reason to stderr and process.exit(2)).
{% elif decision_pattern == "hookSpecificOutput-action-content" %}
  // Blocking event. Set hookSpecificOutput.action to accept / decline / cancel.
{% elif decision_pattern == "display-content" %}
  // Non-blocking event. Set hookSpecificOutput.displayContent to override what is shown.
{% elif decision_pattern == "hookSpecificOutput-decision-behavior" %}
  // Blocking event. Set hookSpecificOutput.decision.behavior to "allow" or "deny".
{% elif decision_pattern == "hookSpecificOutput-retry" %}
  // Non-blocking event. Set hookSpecificOutput.retry=true to let the model retry the denied call.
{% endif %}
  const decision = handle(event);
  if (decision !== null) {
    console.log(JSON.stringify(serialize{{ output_class }}(decision)));
  }
}
{% endif %}

function readStdin(): string {
  return readFileSync(0, "utf-8");
}
