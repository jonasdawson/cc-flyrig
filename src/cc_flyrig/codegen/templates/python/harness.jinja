def run(handle) -> int:
    """Read the hook event from stdin, call handle(), and write any decision to stdout.

    Returns 0. handle() may call sys.exit(2) to signal a denial via exit code instead of JSON.
    """
    event = {{ input_class }}.from_dict(json.loads(sys.stdin.read()))
{% if decision_pattern == "none" %}
    # Non-blocking event. Side-effect only — no output is serialized.
    handle(event)
{% elif decision_pattern == "worktree-path-return" %}
    # Blocking event. Command hooks print the worktree path to stdout as a bare string (not JSON).
    decision = handle(event)
    if decision is not None and decision.hook_specific_output is not None:
        print(decision.hook_specific_output.worktree_path)
{% elif decision_pattern == "hookSpecificOutput-permissionDecision" %}
    # Blocking event. Exit 0 with JSON whose hook_specific_output.permission_decision is one of
    # allow / deny / ask / defer. To deny via exit code instead, write a reason to stderr and
    # sys.exit(2). Returning None takes no action and lets other hooks / the default decide.
    decision = handle(event)
    if decision is not None:
        print(json.dumps(decision.to_dict()))
{% elif decision_pattern == "top-level-decision" %}
    # Blocking event. Set decision="block" and reason to stop the action. Returning None allows.
    decision = handle(event)
    if decision is not None:
        print(json.dumps(decision.to_dict()))
{% elif decision_pattern == "context-only" %}
    # Non-blocking event. Set hook_specific_output fields to inject context. Returning None is a no-op.
    decision = handle(event)
    if decision is not None:
        print(json.dumps(decision.to_dict()))
{% elif decision_pattern == "exit-code-or-continue" %}
    # Blocking event. Set continue_=False to stop (or write a reason to stderr and sys.exit(2)).
    decision = handle(event)
    if decision is not None:
        print(json.dumps(decision.to_dict()))
{% elif decision_pattern == "hookSpecificOutput-action-content" %}
    # Blocking event. Set hook_specific_output.action to accept / decline / cancel.
    decision = handle(event)
    if decision is not None:
        print(json.dumps(decision.to_dict()))
{% elif decision_pattern == "display-content" %}
    # Non-blocking event. Set hook_specific_output.display_content to override what is shown.
    decision = handle(event)
    if decision is not None:
        print(json.dumps(decision.to_dict()))
{% elif decision_pattern == "hookSpecificOutput-decision-behavior" %}
    # Blocking event. Set hook_specific_output.decision.behavior to "allow" or "deny".
    decision = handle(event)
    if decision is not None:
        print(json.dumps(decision.to_dict()))
{% elif decision_pattern == "hookSpecificOutput-retry" %}
    # Non-blocking event. Set hook_specific_output.retry=True to let the model retry the denied call.
    decision = handle(event)
    if decision is not None:
        print(json.dumps(decision.to_dict()))
{% elif decision_pattern == "text-return" %}
    # Freeform text surface (statusLine). No output model — print exactly what handle() returns.
    line = handle(event)
    print(line)
{% elif decision_pattern == "jsonlines-rows" %}
    # subagentStatusLine: one {{ output_class }} row per visible subagent, one JSON object per line.
    rows = handle(event)
    for row in rows:
        print(json.dumps(row.to_dict()))
{% endif %}
    return 0
